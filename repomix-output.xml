                    >
                      {topic.mcqFile ? "Change MCQ" : "Add MCQ"}
                    </button>
                  </div>
                  <div>
                    <label className="block text-xs font-medium mb-1 text-gray-600 dark:text-gray-400">Topic Title</label>
                    <input
