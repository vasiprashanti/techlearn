    const isStandaloneC = (str) => {
      return str.split(/\W+/).some(word => word === 'c');
    };
    if ((isStandaloneC(topic) && !topic.includes('c++')) || (isStandaloneC(starter) && !starter.includes('c++'))) return 'c';
