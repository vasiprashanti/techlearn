                    ${
                      isActive
                        ? "after:w-full text-blue-600 font-medium"
                        : "after:w-0 text-gray-800 dark:text-gray-200 hover:text-blue-500"
                    }`
                  }
                >
                  <span>{item.title}</span>
                </NavLink>
              </motion.div>
            ))}
          </div>
        </div>
      </div>

      {/* Mobile Menu Button */}
      <button
