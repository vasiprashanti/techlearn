const ProgressDonut = ({ 
  title = "Progress", 
  progress = 0, 
  subtitle = "goals",
  loading = false,
  error = null
}) => {
  const radius = 80;
  const circumference = 2 * Math.PI * radius;
  const safeProgress = Math.min(100, Math.max(0, progress));
  const offset = circumference - (safeProgress / 100) * circumference;

  return (
