              rel="noopener noreferrer"
              className="contact-btn bg-[#00225c] hover:bg-[#001a4a] text-white px-8 py-4 rounded-full text-lg transition-all duration-300 hover:scale-105 border border-white/20 backdrop-blur-sm"
