                                  <input
                                    type="file"
                                    accept=".md"
                                    className="hidden"
                                    onChange={e => handleMcqFileUpload(i, e.target.files?.[0] || null)}
                                  />
                                  Upload MCQ .md
                                </label>
                                {topic.mcqStatus && (
                                  <span className="text-xs text-green-600 dark:text-green-400">
                                    {topic.mcqStatus}
                                  </span>
                                )}
                              </div>
                            </div>
                          </td>
                        </tr>
                      )}
                    </React.Fragment>
                  ))}
                  {topics.length === 0 && (
                    <tr>
                      <td colSpan={4} className="text-center py-8 text-gray-400 italic">
