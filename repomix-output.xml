    { id: 'preview', label: 'Live Preview', icon: Eye }
  ];

  // Navigation functions for mobile slide
  const getCurrentTabIndex = () => {
    // Handle codePreview state for mobile navigation
    const tabId = activeTab === 'codePreview' ? 'compiler' : activeTab;
